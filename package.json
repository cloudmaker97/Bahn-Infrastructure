{
  "name": "isr-streckennetz",
  "version": "1.0.1",
  "description": "DB infrastructure register (ISR): data export, Next.js/MapLibre map, routing, and TUI search",
  "type": "module",
  "scripts": {
    "start": "tsx src/main.ts",
    "dev": "tsx watch src/main.ts",
    "dev:web": "npm --prefix web run dev",
    "scrape": "tsx src/scrape.ts",
    "build:data": "tsx src/build-map-data.ts",
    "build:web": "npm --prefix web run build",
    "build": "tsc && npm run build:web",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["isr", "deutsche-bahn", "streckennetz", "routing", "maplibre", "nextjs"],
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
